{
  "name": "Starliner",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "fmt": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint --fix",
    "icons": "npx @svgr/cli --out-dir app/components/atoms/icons --typescript --no-prettier -- assets/icons && npm run fmt",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:migrate": "npx drizzle-kit migrate",
    "openapi:generate": "openapi-generator-cli generate -i '../server/cmd/api/docs/swagger.yaml' -g typescript-axios -o app/server/api/client/generated && prettier app/server/api/client/generated --write"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "^7.7.1",
    "@react-router/serve": "^7.7.1",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-query-devtools": "^5.87.4",
    "@trpc/client": "^11.5.1",
    "@trpc/server": "^11.5.1",
    "@trpc/tanstack-react-query": "^11.5.1",
    "@xyflow/react": "^12.8.6",
    "axios": "^1.12.2",
    "better-auth": "^1.3.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "elkjs": "^0.11.0",
    "framer-motion": "^12.23.22",
    "isbot": "^5.1.27",
    "pg": "^8.16.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^3.0.6",
    "react-router": "^7.7.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "throttle-debounce": "^5.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@react-router/dev": "^7.7.1",
    "@svgr/cli": "^8.1.0",
    "@tailwindcss/vite": "^4.1.12",
    "@tanstack/eslint-plugin-query": "^5.86.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/throttle-debounce": "^5.0.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^6.3.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
